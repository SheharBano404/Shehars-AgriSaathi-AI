# Copy this file to .env (or export these as real environment variables)
# and fill in your own values. Never commit a real .env file with secrets.

# --- Required for live (LLM-powered) mode ---
# Get a free Gemini API key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY="your-api-key-here"

# --- Optional ---
# Override the Gemini model used by every agent (default: gemini-2.5-flash)
AGRISAATHI_MODEL=gemini-2.5-flash

# Directory where the security audit log (audit_log.jsonl) is written
# (default: ./logs relative to the repo root)
AGRISAATHI_LOG_DIR=./logs

# If you use Vertex AI instead of an AI Studio API key, set this to 1 and
# configure standard Google Cloud auth (gcloud auth application-default login)
GOOGLE_GENAI_USE_VERTEXAI=0
